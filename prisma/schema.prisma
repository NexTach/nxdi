generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model PortfolioHolding {
  symbol               String   @id
  name                 String
  alias                String?  @db.VarChar(80)
  marketCountry        String
  currency             String
  quantity             Float
  lastPrice            Float
  averagePurchasePrice Float?
  purchaseExchangeRate Float?
  profitLossRate       Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PortfolioDailySnapshot {
  snapshotDate        String   @id @db.VarChar(10)
  totalMarketValueKrw Float
  exchangeRate        Float
  costBasisKrw        Float?
  annualDividendKrw   Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([updatedAt])
}

model DividendRecord {
  symbol                 String   @id
  currency               String
  annualDividendPerShare Float
  trailingYield          Float?
  expectedPaymentMonths  String   @db.VarChar(80)
  lastDividendPerShare   Float?
  memo                   String?  @db.VarChar(500)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Disclosure {
  id        String            @id @default(cuid())
  title     String            @db.VarChar(160)
  body      String            @db.Text
  trades    DisclosureTrade[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([createdAt])
}

model DisclosureTrade {
  id            String     @id @default(cuid())
  disclosureId  String
  disclosure    Disclosure @relation(fields: [disclosureId], references: [id], onDelete: Cascade)
  side          String
  symbol        String     @db.VarChar(20)
  name          String
  alias         String?    @db.VarChar(80)
  marketCountry String
  currency      String
  quantity      Float
  orderPrice    Float
  exchangeRate  Float?
  profitRate    Float
  feeKrw        Int        @default(0)
  taxKrw        Int        @default(0)
  orderedAt     DateTime
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([disclosureId])
  @@index([symbol])
}

model InvestmentIntent {
  id                String   @id @default(cuid())
  userId            String
  userName          String
  userEmail         String
  amountKrw         Int
  depositorName     String
  contact           String
  guardianConfirmed Boolean  @default(false)
  status            String   @default("PENDING")
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model WithdrawalIntent {
  id            String   @id @default(cuid())
  userId        String
  userName      String
  userEmail     String
  amountKrw     Int
  bankName      String
  accountNumber String
  accountHolder String
  contact       String
  status        String   @default("PENDING")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
}
